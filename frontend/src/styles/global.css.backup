html, body, #root {
  margin: 0;
  padding: 0;
  height: 100%;
  background: #1a1a1a;
  color: #e0e0e0;
  font-family: 'Microsoft YaHei', 'Segoe UI', sans-serif;
}

* { box-sizing: border-box; }

.flow-canvas .react-flow__background {
  background: #1a1a1a;
}
.react-flow__node {
  font-size: 12px;
  color: #e0e0e0;
}
.react-flow__handle {
  width: 12px;
  height: 12px;
  border: 2px solid #1a1a1a;
}
.handle-image { background: #4caf50; }
.handle-video { background: #2196f3; }
.handle-text  { background: #b0bec5; }
.handle-refs  { background: #ff9800; }
.handle-mask  { background: #ce93d8; }
.handle-audio { background: #80cbc4; }

.node-shell {
  background: linear-gradient(135deg, #2d2d2d, #1f1f1f);
  border: 1px solid #3a3a3a;
  border-radius: 8px;
  min-width: 220px;
  padding: 8px 10px 10px 10px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.4);
}
.node-shell.selected { border-color: #4fc3f7; }
.node-shell.running  { border-color: #4caf50; animation: pulse 1.4s infinite; }
.node-shell.failed   { border-color: #f44336; }
@keyframes pulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(76,175,80,0.5); }
  50%     { box-shadow: 0 0 0 6px rgba(76,175,80,0); }
}
.node-title {
  display: flex;
  align-items: center;
  font-weight: 600;
  margin-bottom: 6px;
  gap: 6px;
  color: #fff;
}
.node-title .dot {
  width: 8px; height: 8px; border-radius: 50%;
}
.node-thumb {
  width: 100%;
  max-height: 160px;
  border-radius: 4px;
  background: #111;
  margin: 4px 0;
  display: block;
  object-fit: contain;
}
.node-row {
  display: flex; align-items: center; gap: 6px; margin: 4px 0;
}
.node-label {
  font-size: 11px; color: #9e9e9e;
}

.editor-shell {
  display: grid;
  grid-template-columns: 220px 1fr 220px;
  grid-template-rows: 48px 1fr;
  height: 100vh;
  background: #1a1a1a;
}
.editor-toolbar {
  grid-column: 1 / 4;
  grid-row: 1;
  display: flex;
  align-items: center;
  padding: 0 12px;
  gap: 8px;
  background: #1f1f1f;
  border-bottom: 1px solid #2a2a2a;
}
.editor-left   { grid-column: 1; grid-row: 2; overflow: auto; border-right: 1px solid #2a2a2a; }
.editor-center { grid-column: 2; grid-row: 2; position: relative; }
.editor-right  { grid-column: 3; grid-row: 2; overflow: auto; border-left: 1px solid #2a2a2a; padding: 8px; }

.banner {
  position: absolute; top: 8px; left: 50%; transform: translateX(-50%);
  padding: 6px 14px; border-radius: 4px; font-size: 12px; z-index: 100;
}
.banner-info { background: rgba(33,150,243,0.85); }
.banner-success { background: rgba(76,175,80,0.85); }
.banner-failed { background: rgba(244,67,54,0.85); }

.proj-list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 16px; padding: 24px;
}
.proj-card {
  background: #242424;
  border: 1px solid #2f2f2f;
  border-radius: 8px;
  padding: 16px;
  cursor: pointer;
}
.proj-card:hover { border-color: #4fc3f7; }
.proj-card .name { font-size: 14px; color: #fff; margin-bottom: 4px; }
.proj-card .path { font-size: 11px; color: #777; word-break: break-all; }

.help-line {
  font-size: 11px;
  color: #b0b0b0;
  padding: 2px 0;
}

.node-token {
  font-size: 10px;
  color: #80cbc4;
  text-align: right;
  margin-top: 2px;
}

.node-warn {
  font-size: 11px;
  color: #ffab40;
  margin: 4px 0;
}

.node-cfg-display {
  font-size: 11px;
  color: #4fc3f7;
  margin-left: 6px;
}

/* Output 缩略图 180x100，与 testdir 一致 */
.output-thumb {
  width: 180px;
  height: 100px;
  background: #0d0d0d;
  border-radius: 4px;
  display: block;
  object-fit: cover;
  margin-top: 4px;
}

/* 拖拽中的 ghost 节点轮廓 */
.template-ghost {
  pointer-events: none;
  position: fixed;
  border: 2px dashed #4fc3f7;
  background: rgba(79, 195, 247, 0.1);
  border-radius: 4px;
  z-index: 1000;
}

.quick-add-item {
  padding: 6px 10px;
  cursor: pointer;
  font-size: 12px;
  color: #e0e0e0;
}
.quick-add-item:hover {
  background: #2a2a2a;
}